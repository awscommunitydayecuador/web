---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Únete a AWS Community Day Ecuador 2025, el evento más importante para la comunidad de AWS en Ecuador. Disfruta de charlas, talleres y la oportunidad de aprender sobre las últimas tecnologías de AWS.",
  image = "/assets/images/logo.webp",
} = Astro.props;

// Base URL for canonical links
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
